ZHIPU_API_KEY = 6db05829ecbf42e8ad2da490c43adb78.5pEkfwUPJMDyOf7K

# ---- Supabase ----
# 在 Supabase 控制台 → Project Settings → Database → Connection string 中获取
# 使用 Transaction Pooler (端口 6543) 用于应用运行时连接
