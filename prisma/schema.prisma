// ============================================================
// Prisma Schema 定义 - JavaScript 学习 Agent 数据库模型
// 数据库：Supabase (PostgreSQL + pgvector)
// ============================================================

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户模型
// 存储学习用户的基本信息和学习偏好
// ============================================================
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 认证信息
  username  String   @unique
  password  String   // 简单系统，目前明文存储

  // 基本信息
  email     String?  @unique
  name      String?
  avatarUrl String?  @map("avatar_url")

  // 学习偏好
  skillLevel   String  @default("beginner") @map("skill_level")
  // beginner | intermediate | advanced
  
  // 角色定位 (AI 评估生成)
  rolePosition String? @map("role_position")
  roleReport   String? @map("role_report")

  // 关联
  chatSessions ChatSession[]
  courseStages CourseStage[]

  @@map("users")
}

// ============================================================
// 课程阶段模型
// 记录用户在每个课程阶段的详细状态和生成的 AI 数据
// ============================================================
model CourseStage {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String   @map("course_id") // 对应 STAGES 中的 id

  // 学习阶段状态机
  // 阶段枚举：PRE_ASSESSMENT | PRE_REPORT | STUDY_OUTLINE | STUDYING | POST_ASSESSMENT | POST_REPORT | COMPLETED
  status          String   @default("PRE_ASSESSMENT")

  // 持久化的 AI 生成数据 (存储为 JSON 字符串)
  preQuestions    String?  @map("pre_questions") // 课前问卷
  preReport       String?  @map("pre_report")    // 问卷报告
  learningOutline String?  @map("learning_outline") // 学习大纲 (sections)
  postQuestions   String?  @map("post_questions") // 课后问卷
  postReport      String?  @map("post_report")    // 课后报告

  // 关联的各章节教程内容
  sectionContents SectionContent[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, courseId])
  @@map("course_stages")
}

// ============================================================
// 章节内容模型
// 存储具体章节的 AI 生成教程内容
// ============================================================
model SectionContent {
  id        String   @id @default(cuid())
  stageId   String   @map("stage_id")
  stage     CourseStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  sectionId String   @map("section_id") // 对应大纲中的 section.id
  content   String   // Markdown 内容
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([stageId, sectionId])
  @@map("section_contents")
}

// ============================================================
// 对话会话模型
// 每个学习会话对应一个独立的对话记录
// ============================================================
model ChatSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 会话标题（首次对话后自动生成）
  title     String  @default("新的学习会话")
  // 会话是否已归档
  archived  Boolean @default(false)

  // 关联用户（可选，支持匿名用户）
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 关联的消息列表
  messages  ChatMessage[]

  @@map("chat_sessions")
}

// ============================================================
// 聊天消息模型
// 记录对话中的每一条消息（用户或 AI）
// ============================================================
model ChatMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  // 消息角色：user | assistant | system
  role      String
  // 消息内容（Markdown 格式）
  content   String

  // 所属会话
  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
